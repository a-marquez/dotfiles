{
	/*
	 * START: VS Code configuration
	 */
	"application.shellEnvironmentResolutionTimeout": 15,
	"debug.javascript.autoAttachFilter": "disabled",
	"diffEditor.renderSideBySide": true,
	"editor.accessibilitySupport": "off",
	"editor.codeActionsOnSave": {
		"source.fixAll.eslint": "explicit"
	},
	"editor.cursorSurroundingLines": 5,
	"editor.defaultFormatter": "esbenp.prettier-vscode",
	"editor.detectIndentation": false,
	"editor.fontFamily": "Fira Code, Menlo, Monaco, 'Courier New', monospace",
	"editor.lineNumbers": "relative",
	"editor.minimap.enabled": false,
	"editor.renderWhitespace": "all",
	"editor.rulers": [80],
	"editor.tabSize": 4,
	"explorer.confirmDragAndDrop": false,
	"explorer.fileNesting.enabled": true,
	"explorer.fileNesting.patterns": {
		"*.cts": "${capture}.typegen.ts",
		"*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
		"*.jsx": "${capture}.js",
		"*.mts": "${capture}.typegen.ts",
		"*.ts": "${capture}.js, ${capture}.typegen.ts",
		"*.tsx": "${capture}.ts, ${capture}.typegen.ts",
		"package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb",
		"tsconfig.json": "tsconfig.*.json"
	},
	"git.autofetch": true,
	"git.terminalAuthentication": false,
	"github.gitAuthentication": false,
	"javascript.preferences.importModuleSpecifier": "non-relative",
	"javascript.updateImportsOnFileMove.enabled": "always",
	"security.allowedUNCHosts": ["wsl.localhost"],
	"security.workspace.trust.untrustedFiles": "open",
	"terminal.integrated.scrollback": 10000,
	"typescript.preferences.importModuleSpecifier": "non-relative",
	"typescript.updateImportsOnFileMove.enabled": "always",
	"workbench.colorTheme": "Monokai",
	"workbench.editor.editorActionsLocation": "titleBar",
	"workbench.editor.revealIfOpen": true,
	"workbench.startupEditor": "none",
	"zenMode.hideLineNumbers": false,
	"zenMode.hideStatusBar": false,
	/*
	 * END: VS Code configuration
	 */
	/*
	 * START: Cursor configuration
	 */
	"cursor.inlineDiff.mode": "unified",
	/*
	 * END: Cursor configuration
	 */

	/*
	 * START: Vim extension
	 */
	"vim.foldfix": true,
	"vim.highlightedyank.enable": true,
	"vim.hlsearch": true,
	"vim.incsearch": true,
	"vim.leader": ";",
	"vim.normalModeKeyBindingsNonRecursive": [
		{
			"before": ["<leader>", "<leader>"],
			"commands": [":nohl"]
		},
		{
			"before": ["<leader>", "z"],
			"commands": ["workbench.action.toggleMaximizeEditorGroup"]
		},
		{
			"before": ["<leader>", "p"],
			"commands": ["workbench.action.showCommands"]
		},
		{
			"before": ["<leader>", "f"],
			"commands": ["workbench.action.quickOpen"]
		},
		{
			"before": ["<leader>", "w", "w"],
			"commands": ["workbench.action.files.save"]
		},
		{
			"before": ["<leader>", "q"],
			"commands": ["workbench.action.closeActiveEditor"]
		},
		{
			"before": ["<leader>", "Q"],
			"commands": ["workbench.action.closeEditorsAndGroup"]
		},
		{
			"before": ["<C-w>"],
			"commands": ["workbench.action.closeActiveEditor"],
			"when": "isWindows"
		},
		{
			"before": ["<leader>", "c", "m"],
			"commands": ["editor.action.blockComment"]
		},
		{
			"before": ["<leader>", "c", "c"],
			"commands": ["editor.action.commentLine"]
		},
		{
			"before": ["<leader>", "c", "u"],
			"commands": ["editor.action.removeCommentLine"]
		},
		{
			"before": ["<leader>", "w", "H"],
			"commands": ["workbench.action.moveEditorToLeftGroup"]
		},
		{
			"before": ["<leader>", "w", "L"],
			"commands": ["workbench.action.moveEditorToRightGroup"]
		},
		{
			"before": ["<leader>", "w", "J"],
			"commands": ["workbench.action.moveEditorToBelowGroup"]
		},
		{
			"before": ["<leader>", "w", "K"],
			"commands": ["workbench.action.moveEditorToAboveGroup"]
		},
		{
			"before": ["<leader>", "w", "h"],
			"commands": ["workbench.action.navigateLeft"]
		},
		{
			"before": ["<leader>", "w", "l"],
			"commands": ["workbench.action.navigateRight"]
		},
		{
			"before": ["<leader>", "w", "j"],
			"commands": ["workbench.action.navigateDown"]
		},
		{
			"before": ["<leader>", "w", "k"],
			"commands": ["workbench.action.navigateUp"]
		},
		{
			"before": ["<leader>", "W", "H"],
			"commands": ["workbench.action.newGroupLeft"]
		},
		{
			"before": ["<leader>", "W", "L"],
			"commands": ["workbench.action.newGroupRight"]
		},
		{
			"before": ["<leader>", "W", "J"],
			"commands": ["workbench.action.newGroupDown"]
		},
		{
			"before": ["<leader>", "W", "K"],
			"commands": ["workbench.action.newGroupUp"]
		},
		{
			"before": ["<leader>", "v", "x"],
			"commands": [
				{
					"command": "stately-xstate.edit"
				},
				{
					"command": "workbench.action.focusLastEditorGroup"
				}
			]
		},
		{
			"before": ["<leader>", "v", "m"],
			"commands": ["markdown.showPreviewToSide"]
		},
		{
			"before": ["<leader>", "i"],
			"commands": ["editor.action.showDefinitionPreviewHover"]
		},
		{
			"before": ["<leader>", "r"],
			"commands": ["references-view.findReferences"]
		},
		{
			"before": ["<leader>", "R"],
			"commands": ["editor.action.rename"]
		},
		{
			"before": ["<leader>", "6"],
			"commands": [
				{
					"command": "workbench.action.openPreviousEditorFromHistory"
				},
				{
					"command": "workbench.action.acceptSelectedQuickOpenItem"
				}
			]
		},
		{
			"before": ["g", "D"],
			"commands": [
				{
					"command": "editor.action.revealDefinitionAside"
				}
			]
		},
		{
			"before": ["g", "X"],
			"commands": [
				{
					"command": "editor.action.openLink"
				},
				{
					"command": "workbench.action.moveEditorToRightGroup"
				}
			]
		},
		{
			"before": ["<leader>", "v", "h"],
			"commands": [
				"aichat.close-sidebar",
				"workbench.action.closeSidebar",
				"workbench.action.closePanel"
			],
		},
		{
			"before": ["<leader>", "v", "s"],
			"commands": [
				"composer.openChatAsEditor",
				"workbench.action.toggleSidebarVisibility",
				"workbench.action.togglePanel"
			],
		},
	],
	"vim.visualModeKeyBindingsNonRecursive": [
		{
			"before": ["<leader>", "f"],
			"commands": [
				{ "command": "workbench.action.findInFiles" },
				{ "command": "search.action.focusSearchList" }
			],
			"when": "editorFocus && editorHasSelection"
		},
		{
			"before": ["<leader>", "F"],
			"commands": ["search.action.openNewEditor"],
			"when": "editorFocus && editorHasSelection"
		},
		{
			"before": ["<leader>", "R"],
			"commands": ["editor.action.rename"]
		}
	],
	"vim.useSystemClipboard": true,
	/*
	 * END: Vim extension
	 */

	/*
	 * START: Third-party extensions and language-specific
	 */
	"[dockercompose]": {
		"editor.insertSpaces": true,
		"editor.tabSize": 2,
		"editor.autoIndent": "advanced",
		"editor.defaultFormatter": "redhat.vscode-yaml"
	},
	"[github-actions-workflow]": {
		"editor.defaultFormatter": "redhat.vscode-yaml"
	},
	"[xml]": {
		"editor.defaultFormatter": "redhat.vscode-xml"
	},
	"cSpell.blockCheckingWhenTextChunkSizeGreaterThan": 6000,
	"gitlens.hovers.avatars": false,
	"gitlens.hovers.currentLine.over": "line",
	"gitlens.hovers.enabled": false,
	"gitlens.plusFeatures.enabled": false,
	"go.toolsManagement.autoUpdate": true,
	"markdown.extension.toc.slugifyMode": "gitlab",
	"peacock.favoriteColors": [
		{
			"name": "Angular Red",
			"value": "#dd0531"
		},
		{
			"name": "Azure Blue",
			"value": "#007fff"
		},
		{
			"name": "JavaScript Yellow",
			"value": "#f9e64f"
		},
		{
			"name": "Mandalorian Blue",
			"value": "#1857a4"
		},
		{
			"name": "Node Green",
			"value": "#215732"
		},
		{
			"name": "React Blue",
			"value": "#61dafb"
		},
		{
			"name": "Something Different",
			"value": "#832561"
		},
		{
			"name": "Svelte Orange",
			"value": "#ff3d00"
		},
		{
			"name": "Vue Green",
			"value": "#42b883"
		}
	],
	"prettier.useTabs": true,
	"redhat.telemetry.enabled": false,
	"xstate.showVisualEditorWarnings": false
	/*
	 * END: Third-party extensions and language-specific
	 */
}
